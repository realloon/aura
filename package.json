{
  "name": "@realloon/aura",
  "version": "0.3.1",
  "description": "A syntax-highlighting library for streaming output.",
  "license": "MIT",
  "keywords": [
    "highlight",
    "syntax-highlighter"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/main.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "benchmark": "bun run benchmarks/csharp.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
